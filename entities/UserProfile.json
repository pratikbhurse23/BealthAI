{
  "name": "UserProfile",
  "type": "object",
  "properties": {
    "display_name": {
      "type": "string",
      "description": "User's display name"
    },
    "age": {
      "type": "number",
      "description": "User's age in years"
    },
    "gender": {
      "type": "string",
      "enum": [
        "male",
        "female"
      ],
      "description": "User's gender for BMR calculation"
    },
    "weight_kg": {
      "type": "number",
      "description": "Current weight in kilograms"
    },
    "height_cm": {
      "type": "number",
      "description": "Height in centimetres"
    },
    "activity_level": {
      "type": "string",
      "enum": [
        "sedentary",
        "active",
        "athlete"
      ],
      "default": "sedentary",
      "description": "Daily activity level"
    },
    "goal_type": {
      "type": "string",
      "enum": [
        "lose",
        "maintain",
        "gain"
      ],
      "default": "maintain",
      "description": "User's weight goal type"
    },
    "goal_weight_kg": {
      "type": "number",
      "description": "Target weight in kilograms"
    },
    "start_weight_kg": {
      "type": "number",
      "description": "Starting weight when goal was set"
    },
    "medical_conditions": {
      "type": "string",
      "description": "JSON string of medical conditions (diabetes, hypertension, heart, thyroid, pcos, kidney)"
    },
    "doctor_calorie_target": {
      "type": "number",
      "description": "Doctor-prescribed daily calorie target for users with medical conditions"
    },
    "preferred_language": {
      "type": "string",
      "description": "User's preferred app language code (e.g. en, hi, mr)"
    },
    "goal_deadline": {
      "type": "string",
      "description": "ISO date string of target deadline for weight goal"
    },
    "diet_preference": {
      "type": "string",
      "description": "Diet preference: veg, nonveg, vegan, jain"
    },
    "disability_notes": {
      "type": "string",
      "description": "Disability or other medical notes"
    }
  },
  "required": [
    "age",
    "gender",
    "weight_kg",
    "height_cm"
  ]
}