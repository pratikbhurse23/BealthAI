{
  "name": "DietPlan",
  "type": "object",
  "properties": {
    "plan_name": {
      "type": "string",
      "description": "Name of the diet plan"
    },
    "daily_calorie_goal": {
      "type": "number",
      "description": "Daily calorie target"
    },
    "meal_schedule": {
      "type": "string",
      "description": "JSON string of meal schedule"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether this plan is currently active"
    },
    "notifications_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether notifications are enabled"
    },
    "notification_times": {
      "type": "string",
      "description": "JSON string of notification times"
    }
  },
  "required": [
    "plan_name"
  ]
}